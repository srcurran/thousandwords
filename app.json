{
  "expo": {
    "name": "ThousandWords",
    "slug": "ThousandWords",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.srcurran.ThousandWords",
      "deploymentTarget": "17.0",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Allow access to save images to your photo library",
        "NSPhotoLibraryAddOnlyUsageDescription": "Allow access to save images to your photo library"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-updates"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "16a186ab-badb-434a-8a5a-3f501c820c51"
      }
    },
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/16a186ab-badb-434a-8a5a-3f501c820c51",
      "fallbackToCacheTimeout": 0
    },
    "android": {
      "package": "com.srcurran.ThousandWords",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    }
  }
}
